{
  "name": "historymapcard",
  "version": "1.0.0",
  "description": "Home Assistant custom Lovelace card: Map with history timeline animation",
  "main": "history-map-card.js",
  "scripts": {
    "build": "rollup -c rollup.config.js && terser history-map-card.js -o history-map-card.js --compress --mangle",
    "build:dev": "rollup -c rollup.config.js",
    "dev": "rollup -c rollup.config.js --watch",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "playwright test",
    "test:integration:update": "playwright test --update-snapshots",
    "test:integration:report": "playwright show-report",
    "test:all": "npm run test && npm run test:integration"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/piotrmilcarz/historymapcard.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/piotrmilcarz/historymapcard/issues"
  },
  "homepage": "https://github.com/piotrmilcarz/historymapcard#readme",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@rollup/plugin-commonjs": "^29.0.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/leaflet": "^1.9.21",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vitest/coverage-v8": "^0.34.6",
    "eslint": "^8.57.1",
    "happy-dom": "^20.8.3",
    "jsdom": "^28.1.0",
    "rollup": "^4.59.0",
    "terser": "^5.18.0",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "vitest": "^0.34.6"
  },
  "dependencies": {
    "leaflet": "^1.9.4"
  }
}
